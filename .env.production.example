# 后端生产环境变量模板。复制到服务器环境变量/CI Secret 中使用，不要提交真实密码和密钥。

APP_ENV=production
DB_HOST=101.42.94.41
DB_PORT=3306
DB_NAME=diaoyu
DB_USER=diaoyu
DB_PASSWORD=replace-with-real-db-password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
