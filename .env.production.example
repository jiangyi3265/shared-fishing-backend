# 后端生产环境变量模板。复制到服务器环境变量/CI Secret 中使用，不要提交真实密码和密钥。

APP_ENV=production
DB_HOST=replace-with-db-host
DB_PORT=3306
DB_NAME=replace-with-db-name
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-real-db-password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=

TOKEN_SECRET=replace-with-a-long-random-secret-at-least-32-chars
CORS_ALLOWED_ORIGINS=https://ht.diaoyuus.cn,https://www.diaoyuus.cn
SWAGGER_ENABLED=false
DRUID_STAT_ENABLED=false
DRUID_STAT_USER=ruoyi
DRUID_STAT_PASSWORD=replace-with-druid-password
DEMO_ENABLED=false

WX_APPID=replace-with-miniapp-appid
WX_SECRET=replace-with-miniapp-secret
WX_MOCK_ENABLED=false
WX_TOKEN_EXPIRE_DAYS=30

WX_PAY_ENABLED=true
WX_PAY_MOCK_ENABLED=false
WX_PAY_MCH_ID=replace-with-mch-id
WX_PAY_APIV3=replace-with-apiv3-key
WX_PAY_NOTIFY=https://www.diaoyuus.cn/app/order/pay/notify
WX_PAY_PRIVATE_KEY=/opt/fishing/certs/apiclient_key.pem
WX_PAY_CERT_SERIAL=replace-with-cert-serial
WX_PAY_PUBLIC_KEY=/opt/fishing/certs/wechatpay_public_key.pem
WX_PAY_PUBLIC_KEY_ID=replace-with-wechatpay-public-key-id

WEATHER_QWEATHER_KEY=
