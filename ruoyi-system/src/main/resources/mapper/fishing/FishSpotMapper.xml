<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.fishing.mapper.FishSpotMapper">

    <resultMap type="com.ruoyi.fishing.domain.FishSpot" id="SpotResult">
        <id     property="spotId"        column="spot_id"/>
        <result property="venueId"       column="venue_id"/>
        <result property="venueName"     column="venue_name"/>
        <result property="spotName"      column="spot_name"/>
        <result property="spotType"      column="spot_type"/>
        <result property="extraFeeCents" column="extra_fee_cents"/>
        <result property="capacity"      column="capacity"/>
        <result property="sortNum"       column="sort_num"/>
        <result property="status"        column="status"/>
        <result property="description"   column="description"/>
        <result property="delFlag"       column="del_flag"/>
        <result property="createBy"      column="create_by"/>
        <result property="createTime"    column="create_time"/>
        <result property="updateBy"      column="update_by"/>
        <result property="updateTime"    column="update_time"/>
    </resultMap>

    <sql id="selectVo">
        select s.spot_id, s.venue_id, v.name as venue_name, s.spot_name, s.spot_type,
               s.extra_fee_cents, s.capacity, s.sort_num, s.status, s.description,
               s.del_flag, s.create_by, s.create_time, s.update_by, s.update_time
        from fish_spot s left join fish_venue v on v.venue_id = s.venue_id
    </sql>

    <select id="selectList" parameterType="com.ruoyi.fishing.domain.FishSpot" resultMap="SpotResult">
        <include refid="selectVo"/>
        <where>
            s.del_flag = '0'
            <if test="venueId != null">AND s.venue_id = #{venueId}</if>
            <if test="spotName != null and spotName != ''">AND s.spot_name like concat('%', #{spotName}, '%')</if>
            <if test="spotType != null and spotType != ''">AND s.spot_type = #{spotType}</if>
            <if test="status != null and status != ''">AND s.status = #{status}</if>
        </where>
        order by s.sort_num asc, s.spot_id asc
    </select>

    <select id="selectAvailableByVenue" parameterType="Long" resultMap="SpotResult">
        <include refid="selectVo"/> where s.del_flag = '0' and s.status = '0' and s.venue_id = #{venueId}
        order by s.sort_num asc, s.spot_id asc
    </select>

    <select id="selectById" parameterType="Long" resultMap="SpotResult">
        <include refid="selectVo"/> where s.spot_id = #{spotId} and s.del_flag = '0'
    </select>

    <insert id="insert" parameterType="com.ruoyi.fishing.domain.FishSpot" useGeneratedKeys="true" keyProperty="spotId">
        insert into fish_spot
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="venueId != null">venue_id,</if>
            <if test="spotName != null">spot_name,</if>
            <if test="spotType != null">spot_type,</if>
            <if test="extraFeeCents != null">extra_fee_cents,</if>
            <if test="capacity != null">capacity,</if>
            <if test="sortNum != null">sort_num,</if>
            <if test="status != null">status,</if>
            <if test="description != null">description,</if>
            <if test="createBy != null">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="venueId != null">#{venueId},</if>
            <if test="spotName != null">#{spotName},</if>
            <if test="spotType != null">#{spotType},</if>
            <if test="extraFeeCents != null">#{extraFeeCents},</if>
            <if test="capacity != null">#{capacity},</if>
            <if test="sortNum != null">#{sortNum},</if>
            <if test="status != null">#{status},</if>
            <if test="description != null">#{description},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.fishing.domain.FishSpot">
        update fish_spot
        <trim prefix="SET" suffixOverrides=",">
            <if test="venueId != null">venue_id = #{venueId},</if>
            <if test="spotName != null">spot_name = #{spotName},</if>
            <if test="spotType != null">spot_type = #{spotType},</if>
            <if test="extraFeeCents != null">extra_fee_cents = #{extraFeeCents},</if>
            <if test="capacity != null">capacity = #{capacity},</if>
            <if test="sortNum != null">sort_num = #{sortNum},</if>
            <if test="status != null">status = #{status},</if>
            <if test="description != null">description = #{description},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where spot_id = #{spotId}
    </update>

    <update id="deleteByIds" parameterType="Long">
        update fish_spot set del_flag = '2' where spot_id in
        <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach>
    </update>
</mapper>
