<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.fishing.mapper.FishRegistrationMapper">

    <resultMap type="com.ruoyi.fishing.domain.FishRegistration" id="FishRegistrationResult">
        <id     property="regId"        column="reg_id"/>
        <result property="adId"         column="ad_id"/>
        <result property="userId"       column="user_id"/>
        <result property="name"         column="name"/>
        <result property="phone"        column="phone"/>
        <result property="remark2"      column="remark"/>
        <result property="feeCents"     column="fee_cents"/>
        <result property="paid"         column="paid"/>
        <result property="paidTime"     column="paid_time"/>
        <result property="status"       column="status"/>
        <result property="createTime"   column="create_time"/>
        <result property="activityName" column="activity_name"/>
    </resultMap>

    <sql id="selectVo">
        select r.reg_id, r.ad_id, r.user_id, r.name, r.phone, r.remark, r.fee_cents, r.paid, r.paid_time,
               r.status, r.create_time, a.activity_name as activity_name
        from fish_registration r
        left join fish_ad a on r.ad_id = a.ad_id
    </sql>

    <select id="selectFishRegistrationList" parameterType="com.ruoyi.fishing.domain.FishRegistration" resultMap="FishRegistrationResult">
        <include refid="selectVo"/>
        <where>
            <if test="adId != null">AND r.ad_id = #{adId}</if>
            <if test="userId != null">AND r.user_id = #{userId}</if>
            <if test="name != null and name != ''">AND r.name like concat('%', #{name}, '%')</if>
            <if test="phone != null and phone != ''">AND r.phone like concat('%', #{phone}, '%')</if>
            <if test="paid != null">AND r.paid = #{paid}</if>
            <if test="status != null">AND r.status = #{status}</if>
        </where>
        order by r.reg_id desc
    </select>

    <select id="selectFishRegistrationByRegId" parameterType="Long" resultMap="FishRegistrationResult">
        <include refid="selectVo"/> where r.reg_id = #{regId}
    </select>

    <select id="selectByAdAndUser" resultMap="FishRegistrationResult">
        <include refid="selectVo"/> where r.ad_id = #{adId} and r.user_id = #{userId} and r.status = 0 limit 1
    </select>

    <select id="selectByUserId" resultMap="FishRegistrationResult">
        <include refid="selectVo"/> where r.user_id = #{userId} order by r.reg_id desc
    </select>

    <insert id="insertFishRegistration" parameterType="com.ruoyi.fishing.domain.FishRegistration" useGeneratedKeys="true" keyProperty="regId">
        insert into fish_registration (ad_id, user_id, name, phone, remark, fee_cents, paid, status, create_time)
        values (#{adId}, #{userId}, #{name}, #{phone}, #{remark2}, #{feeCents}, #{paid}, #{status}, sysdate())
    </insert>

    <update id="updateFishRegistration" parameterType="com.ruoyi.fishing.domain.FishRegistration">
        update fish_registration
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null">name = #{name},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="remark2 != null">remark = #{remark2},</if>
            <if test="feeCents != null">fee_cents = #{feeCents},</if>
            <if test="paid != null">paid = #{paid},</if>
            <if test="paidTime != null">paid_time = #{paidTime},</if>
            <if test="status != null">status = #{status},</if>
        </trim>
        where reg_id = #{regId}
    </update>

    <delete id="deleteFishRegistrationByRegId" parameterType="Long">
        delete from fish_registration where reg_id = #{regId}
    </delete>

    <delete id="deleteFishRegistrationByRegIds" parameterType="Long">
        delete from fish_registration where reg_id in
        <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach>
    </delete>
</mapper>
