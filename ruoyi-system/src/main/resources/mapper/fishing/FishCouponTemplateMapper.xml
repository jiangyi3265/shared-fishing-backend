<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.fishing.mapper.FishCouponTemplateMapper">

    <resultMap type="com.ruoyi.fishing.domain.FishCouponTemplate" id="FishCouponTemplateResult">
        <id     property="templateId"      column="template_id"/>
        <result property="title"           column="title"/>
        <result property="couponType"      column="coupon_type"/>
        <result property="couponValue"     column="coupon_value"/>
        <result property="minAmountCents"  column="min_amount_cents"/>
        <result property="validDays"       column="valid_days"/>
        <result property="totalStock"      column="total_stock"/>
        <result property="issuedCount"     column="issued_count"/>
        <result property="source"          column="source"/>
        <result property="status"          column="status"/>
        <result property="delFlag"         column="del_flag"/>
        <result property="createBy"        column="create_by"/>
        <result property="createTime"      column="create_time"/>
        <result property="updateBy"        column="update_by"/>
        <result property="updateTime"      column="update_time"/>
        <result property="remark"          column="remark"/>
    </resultMap>

    <sql id="selectVo">
        select template_id, title, coupon_type, coupon_value, min_amount_cents, valid_days, total_stock,
               issued_count, source, status, del_flag, create_by, create_time, update_by, update_time, remark
        from fish_coupon_template
    </sql>

    <select id="selectFishCouponTemplateList" parameterType="com.ruoyi.fishing.domain.FishCouponTemplate" resultMap="FishCouponTemplateResult">
        <include refid="selectVo"/>
        <where>
            del_flag = '0'
            <if test="title != null and title != ''">AND title like concat('%', #{title}, '%')</if>
            <if test="couponType != null and couponType != ''">AND coupon_type = #{couponType}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        order by template_id desc
    </select>

    <select id="selectFishCouponTemplateByTemplateId" parameterType="Long" resultMap="FishCouponTemplateResult">
        <include refid="selectVo"/> where template_id = #{templateId} and del_flag = '0'
    </select>

    <insert id="insertFishCouponTemplate" parameterType="com.ruoyi.fishing.domain.FishCouponTemplate" useGeneratedKeys="true" keyProperty="templateId">
        insert into fish_coupon_template
        <trim prefix="(" suffix=")" suffixOverrides=",">
            title, coupon_type, coupon_value,
            <if test="minAmountCents != null">min_amount_cents,</if>
            <if test="validDays != null">valid_days,</if>
            <if test="totalStock != null">total_stock,</if>
            <if test="source != null">source,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            #{title}, #{couponType}, #{couponValue},
            <if test="minAmountCents != null">#{minAmountCents},</if>
            <if test="validDays != null">#{validDays},</if>
            <if test="totalStock != null">#{totalStock},</if>
            <if test="source != null">#{source},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateFishCouponTemplate" parameterType="com.ruoyi.fishing.domain.FishCouponTemplate">
        update fish_coupon_template
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null">title = #{title},</if>
            <if test="couponType != null">coupon_type = #{couponType},</if>
            <if test="couponValue != null">coupon_value = #{couponValue},</if>
            <if test="minAmountCents != null">min_amount_cents = #{minAmountCents},</if>
            <if test="validDays != null">valid_days = #{validDays},</if>
            <if test="totalStock != null">total_stock = #{totalStock},</if>
            <if test="issuedCount != null">issued_count = #{issuedCount},</if>
            <if test="source != null">source = #{source},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where template_id = #{templateId}
    </update>

    <update id="deleteFishCouponTemplateByTemplateId" parameterType="Long">
        update fish_coupon_template set del_flag = '2' where template_id = #{templateId}
    </update>

    <update id="deleteFishCouponTemplateByTemplateIds" parameterType="Long">
        update fish_coupon_template set del_flag = '2' where template_id in
        <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach>
    </update>
</mapper>
