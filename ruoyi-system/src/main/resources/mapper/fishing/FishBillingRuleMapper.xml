<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.fishing.mapper.FishBillingRuleMapper">

    <resultMap type="com.ruoyi.fishing.domain.FishBillingRule" id="FishBillingRuleResult">
        <id     property="ruleId"              column="rule_id"/>
        <result property="ruleName"            column="rule_name"/>
        <result property="unitType"            column="unit_type"/>
        <result property="stepMinutes"         column="step_minutes"/>
        <result property="pricePerStepCents"   column="price_per_step_cents"/>
        <result property="minDurationMinutes"  column="min_duration_minutes"/>
        <result property="roundType"           column="round_type"/>
        <result property="capAmountCents"      column="cap_amount_cents"/>
        <result property="dailyCapCents"       column="daily_cap_cents"/>
        <result property="timeSegmentJson"     column="time_segment_json"/>
        <result property="summary"             column="summary"/>
        <result property="status"              column="status"/>
        <result property="delFlag"             column="del_flag"/>
        <result property="createBy"            column="create_by"/>
        <result property="createTime"          column="create_time"/>
        <result property="updateBy"            column="update_by"/>
        <result property="updateTime"          column="update_time"/>
        <result property="remark"              column="remark"/>
    </resultMap>

    <sql id="selectFishBillingRuleVo">
        select rule_id, rule_name, unit_type, step_minutes, price_per_step_cents, min_duration_minutes,
               round_type, cap_amount_cents, daily_cap_cents, time_segment_json, summary, status, del_flag,
               create_by, create_time, update_by, update_time, remark
        from fish_billing_rule
    </sql>

    <select id="selectFishBillingRuleList" parameterType="com.ruoyi.fishing.domain.FishBillingRule" resultMap="FishBillingRuleResult">
        <include refid="selectFishBillingRuleVo"/>
        <where>
            del_flag = '0'
            <if test="ruleName != null and ruleName != ''">AND rule_name like concat('%', #{ruleName}, '%')</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        order by rule_id desc
    </select>

    <select id="selectFishBillingRuleByRuleId" parameterType="Long" resultMap="FishBillingRuleResult">
        <include refid="selectFishBillingRuleVo"/>
        where rule_id = #{ruleId} and del_flag = '0'
    </select>

    <insert id="insertFishBillingRule" parameterType="com.ruoyi.fishing.domain.FishBillingRule" useGeneratedKeys="true" keyProperty="ruleId">
        insert into fish_billing_rule
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="ruleName != null">rule_name,</if>
            <if test="unitType != null">unit_type,</if>
            <if test="stepMinutes != null">step_minutes,</if>
            <if test="pricePerStepCents != null">price_per_step_cents,</if>
            <if test="minDurationMinutes != null">min_duration_minutes,</if>
            <if test="roundType != null">round_type,</if>
            <if test="capAmountCents != null">cap_amount_cents,</if>
            <if test="dailyCapCents != null">daily_cap_cents,</if>
            <if test="timeSegmentJson != null">time_segment_json,</if>
            <if test="summary != null">summary,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="ruleName != null">#{ruleName},</if>
            <if test="unitType != null">#{unitType},</if>
            <if test="stepMinutes != null">#{stepMinutes},</if>
            <if test="pricePerStepCents != null">#{pricePerStepCents},</if>
            <if test="minDurationMinutes != null">#{minDurationMinutes},</if>
            <if test="roundType != null">#{roundType},</if>
            <if test="capAmountCents != null">#{capAmountCents},</if>
            <if test="dailyCapCents != null">#{dailyCapCents},</if>
            <if test="timeSegmentJson != null">#{timeSegmentJson},</if>
            <if test="summary != null">#{summary},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateFishBillingRule" parameterType="com.ruoyi.fishing.domain.FishBillingRule">
        update fish_billing_rule
        <trim prefix="SET" suffixOverrides=",">
            <if test="ruleName != null">rule_name = #{ruleName},</if>
            <if test="unitType != null">unit_type = #{unitType},</if>
            <if test="stepMinutes != null">step_minutes = #{stepMinutes},</if>
            <if test="pricePerStepCents != null">price_per_step_cents = #{pricePerStepCents},</if>
            <if test="minDurationMinutes != null">min_duration_minutes = #{minDurationMinutes},</if>
            <if test="roundType != null">round_type = #{roundType},</if>
            <if test="capAmountCents != null">cap_amount_cents = #{capAmountCents},</if>
            <if test="dailyCapCents != null">daily_cap_cents = #{dailyCapCents},</if>
            <if test="timeSegmentJson != null">time_segment_json = #{timeSegmentJson},</if>
            <if test="summary != null">summary = #{summary},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where rule_id = #{ruleId}
    </update>

    <update id="deleteFishBillingRuleByRuleId" parameterType="Long">
        update fish_billing_rule set del_flag = '2' where rule_id = #{ruleId}
    </update>

    <update id="deleteFishBillingRuleByRuleIds" parameterType="Long">
        update fish_billing_rule set del_flag = '2' where rule_id in
        <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach>
    </update>
</mapper>
