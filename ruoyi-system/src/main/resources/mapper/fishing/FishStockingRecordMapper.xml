<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.fishing.mapper.FishStockingRecordMapper">

    <resultMap type="com.ruoyi.fishing.domain.FishStockingRecord" id="StockingResult">
        <id     property="recordId"     column="record_id"/>
        <result property="venueId"      column="venue_id"/>
        <result property="venueName"    column="venue_name"/>
        <result property="fishSpecies"  column="fish_species"/>
        <result property="weightJin"    column="weight_jin"/>
        <result property="fishCount"    column="fish_count"/>
        <result property="stockingTime" column="stocking_time"/>
        <result property="image"        column="image"/>
        <result property="content"      column="content"/>
        <result property="status"       column="status"/>
        <result property="delFlag"      column="del_flag"/>
        <result property="createBy"     column="create_by"/>
        <result property="createTime"   column="create_time"/>
        <result property="updateBy"     column="update_by"/>
        <result property="updateTime"   column="update_time"/>
        <result property="remark"       column="remark"/>
    </resultMap>

    <sql id="selectStockingVo">
        select r.record_id, r.venue_id, v.name as venue_name,
               r.fish_species, r.weight_jin, r.fish_count, r.stocking_time,
               r.image, r.content, r.status, r.del_flag,
               r.create_by, r.create_time, r.update_by, r.update_time, r.remark
        from fish_stocking_record r
        left join fish_venue v on v.venue_id = r.venue_id
    </sql>

    <select id="selectList" parameterType="com.ruoyi.fishing.domain.FishStockingRecord" resultMap="StockingResult">
        <include refid="selectStockingVo"/>
        <where>
            r.del_flag = '0'
            <if test="venueId != null">AND r.venue_id = #{venueId}</if>
            <if test="fishSpecies != null and fishSpecies != ''">AND r.fish_species like concat('%', #{fishSpecies}, '%')</if>
            <if test="status != null and status != ''">AND r.status = #{status}</if>
            <if test="params.beginTime != null and params.beginTime != ''">AND r.stocking_time &gt;= #{params.beginTime}</if>
            <if test="params.endTime != null and params.endTime != ''">AND r.stocking_time &lt;= #{params.endTime}</if>
        </where>
        order by r.stocking_time desc, r.record_id desc
    </select>

    <select id="selectPublicByVenue" parameterType="Long" resultMap="StockingResult">
        <include refid="selectStockingVo"/>
        where r.del_flag = '0' and r.status = '0'
        <if test="_parameter != null">AND r.venue_id = #{venueId}</if>
        order by r.stocking_time desc, r.record_id desc
        limit 50
    </select>

    <select id="selectByRecordId" parameterType="Long" resultMap="StockingResult">
        <include refid="selectStockingVo"/> where r.record_id = #{recordId} and r.del_flag = '0'
    </select>

    <insert id="insertRecord" parameterType="com.ruoyi.fishing.domain.FishStockingRecord" useGeneratedKeys="true" keyProperty="recordId">
        insert into fish_stocking_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="venueId != null">venue_id,</if>
            <if test="fishSpecies != null">fish_species,</if>
            <if test="weightJin != null">weight_jin,</if>
            <if test="fishCount != null">fish_count,</if>
            <if test="stockingTime != null">stocking_time,</if>
            <if test="image != null">image,</if>
            <if test="content != null">content,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="venueId != null">#{venueId},</if>
            <if test="fishSpecies != null">#{fishSpecies},</if>
            <if test="weightJin != null">#{weightJin},</if>
            <if test="fishCount != null">#{fishCount},</if>
            <if test="stockingTime != null">#{stockingTime},</if>
            <if test="image != null">#{image},</if>
            <if test="content != null">#{content},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateRecord" parameterType="com.ruoyi.fishing.domain.FishStockingRecord">
        update fish_stocking_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="venueId != null">venue_id = #{venueId},</if>
            <if test="fishSpecies != null">fish_species = #{fishSpecies},</if>
            <if test="weightJin != null">weight_jin = #{weightJin},</if>
            <if test="fishCount != null">fish_count = #{fishCount},</if>
            <if test="stockingTime != null">stocking_time = #{stockingTime},</if>
            <if test="image != null">image = #{image},</if>
            <if test="content != null">content = #{content},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where record_id = #{recordId}
    </update>

    <update id="deleteByRecordId" parameterType="Long">
        update fish_stocking_record set del_flag = '2' where record_id = #{recordId}
    </update>

    <update id="deleteByRecordIds" parameterType="Long">
        update fish_stocking_record set del_flag = '2' where record_id in
        <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach>
    </update>
</mapper>
